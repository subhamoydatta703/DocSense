# Backend Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@db:5432/docsense?schema=public"
WORKER_DATABASE_URL="postgresql://postgres:postgres@db:5432/docsense?schema=public"

# Redis Config (standardized names)
REDIS_URL="redis://redis:6379"
BULLMQ_REDIS_URL="redis://redis:6379"

# Clerk Authentication (backend-only)
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# S3 Object Storage Config (backend-only)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME="docsense-bucket"

# Google AI Config (backend-only)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_API_KEY=your_gemini_embedding_api_key_here

# Frontend Config (Baked into build during Docker Compose build)
VITE_API_URL="http://localhost:5000/api"
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
